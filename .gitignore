# Unit-test binaries (glob + un-ignore sources: the old per-binary
# list silently missed newly added tests, e.g. test_midi)
tests/unit/test_*
!tests/unit/test_*.c
tests/unit/*.cov

# Editor backups
*.bak

# Test outputs (typically written to /tmp; included defensively)
/tmp/*.wav

# Stray working-tree docs (historical design doc re-extracted into the tree)
The 64KB Wotja - A Decision-Ready Plan for a Demoscene-Style Generative Music Player on Linux.md

# Agent scratch artifacts (PR bodies / commit messages drafted during
# spec-kit runs; the canonical copies live on the GitHub PRs / commits)
.specify/PR-*-body.md
.specify/commit_msg_*.txt
commit_msg*.txt

# One-off local measurement artifacts
synth.stripped

# Per-user Claude Code settings (machine-local permissions)
.claude/settings.local.json
