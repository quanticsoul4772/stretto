# Maintainer: rbsmith4 <rbsmith4@gmail.com>
#
# sha256 pinned against the public archive URL (repo made public
# 2026-07-09). Remaining checklist:
#   1. Push PKGBUILD + .SRCINFO to ssh://aur@aur.archlinux.org/stretto.git
#      (requires the maintainer's AUR account; optionally regenerate
#      .SRCINFO with `makepkg --printsrcinfo > .SRCINFO` first - the
#      committed one is hand-written to the same content).
pkgname=stretto
pkgver=1.3.0
pkgrel=1
pkgdesc="Tiny deterministic generative music synthesizer (C99, no malloc, single 128 KB arena)"
arch=('x86_64')
url="https://github.com/quanticsoul4772/stretto"
license=('MIT')
depends=('libpulse' 'alsa-lib')
makedepends=('gcc' 'make')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('26a50398d9d15a56733aee36f585dd2a72d2df0c75fafd8d151c0e6d2dd85c0f')

build() {
  cd "$pkgname-$pkgver"
  # Tarball builds have no .git; STRETTO_VERSION overrides the
  # git-describe machinery so --version reports the release, not "dev".
  make STRETTO_VERSION="$pkgver"
}

check() {
  cd "$pkgname-$pkgver"
  # Pure-synth unit suite (no TTY / audio device / PulseAudio server
  # needed; links libasound from depends). STRETTO_VERSION passed so
  # the always-run version.h recipe does not flip the file to "dev"
  # between build() and package().
  make test-unit STRETTO_VERSION="$pkgver"
}

package() {
  cd "$pkgname-$pkgver"
  # The upstream install target is DESTDIR/PREFIX-aware and installs
  # the binary under its canonical name plus the man page.
  make install STRETTO_VERSION="$pkgver" DESTDIR="$pkgdir" PREFIX=/usr
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
